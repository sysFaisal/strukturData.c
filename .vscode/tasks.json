{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build jam library",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-c",
                "${workspaceFolder}/praktikum/1. Array/jam.c",
                "-o",
                "${workspaceFolder}/praktikum/1. Array/jam.o"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Compile jam.c to object file (no main)."
        },

        {
            "label": "build program",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/gcc.exe",
            "dependsOn": "build jam library",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "${workspaceFolder}/praktikum/1. Array/jam.o",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compile active file and link with jam.o (run this for mjam.c)."
        }
    ]
}